# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB — use Atlas URI for production data, or local Mongo for dev
MONGODB_URI=mongodb://127.0.0.1:27017/ssc_prep

# Required on Render/production (generate with: openssl rand -base64 48)
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Optional
PORT=5000
NODE_ENV=development

# Your Vercel URL — REQUIRED on Render for CORS (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# JWT token lifetime (default 7d)
# JWT_EXPIRES_IN=7d
