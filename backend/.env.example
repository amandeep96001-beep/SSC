# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB — use Atlas URI for production data, or local Mongo for dev
MONGODB_URI=mongodb://127.0.0.1:27017/ssc_prep

# Required on Render/production (generate with: openssl rand -base64 48)
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Optional
PORT=5000
NODE_ENV=development

# Browser origin allowed by CORS (exact origin, no trailing slash).
# Local: http://localhost:5173
# Render: MUST be your Vercel URL, e.g. https://myexamprep-theta.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional extra origins (comma-separated), e.g. preview deploys / custom domains
# FRONTEND_URLS=https://myexamprep-theta.vercel.app,https://myexamprep-git-main.vercel.app

# JWT token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Admin: any user who signs in with this email becomes admin
# ADMIN_EMAIL=you@institute.com

# --- Email OTP (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM="ExamPrep <your@gmail.com>"
# Set SMTP_DEBUG=1 only for local testing (shows OTP in API response when mail fails)
# SMTP_DEBUG=0

# Study reminders cron (1 = on, 0 = off). Server checks every minute; emails + in-app notifications.
# Requires SMTP + user email on the account for email delivery.
# REMINDER_CRON=1

# --- Google Sign-In (Google Identity Services popup / auth-code) ---
# Same Client ID must be in frontend/.env.local as VITE_GOOGLE_CLIENT_ID
#
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application):
#   Authorized JavaScript origins:
#     http://localhost:5173
#     https://myexamprep-theta.vercel.app
#   OAuth consent screen (if Testing): add your email as Test user
# Client secret is required for the popup auth-code exchange.
#
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
