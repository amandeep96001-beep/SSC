# Copy to .env.local for Vite:
#   cp .env.example .env.local

# API base. Leave unset on Vercel to use same-origin /api (proxied via vercel.json).
# Local: http://localhost:5000/api
# Direct (cross-origin): https://ssc-3-3rlh.onrender.com/api
# VITE_API_URL=http://localhost:5000/api

# Google Identity Services — SAME Client ID as backend GOOGLE_CLIENT_ID
# Google Cloud Console → APIs & Services → Credentials
#   1. Create OAuth client type: Web application
#   2. Authorized JavaScript origins → add: http://localhost:5173
#      and https://myexamprep-theta.vercel.app
#      (no trailing slash; do NOT put this under Redirect URIs for this flow)
#   3. Paste Client ID below
VITE_GOOGLE_CLIENT_ID=
